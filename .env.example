# Connection string de Postgres (Supabase → Connect → Session/Transaction pooler).
# La app usa el puerto 6543 (transaction mode); los scripts de importación
# cambian automáticamente al 5432 (session mode).
SUPABASE_DB_URL=postgresql://postgres.PROYECTO:PASSWORD@REGION.pooler.supabase.com:6543/postgres

# Salt aleatorio para hashear IPs en la auditoría (openssl rand -hex 16)
RATE_SALT=

# Opcional: URL del proyecto Supabase, solo para el chequeo informativo
# del estado de la API REST en scripts/check-db.mjs
SUPABASE_URL=
